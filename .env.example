# Gmail credentials
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Absolute path to your CSV file
CSV_FILE_PATH=C:/path/to/participants.csv

# -----------------------------------------------------------------------
# Mode — choose one per run:
#   html        → sends personalised HTML email (template/email_template.html)
#   attachment  → generates personalised PDF from PPTX and sends as attachment
# -----------------------------------------------------------------------
MODE=html

# -----------------------------------------------------------------------
# Attachment mode settings (only used when MODE=attachment)
# -----------------------------------------------------------------------

# Absolute path to your PPTX template file
# Design the slide in PowerPoint with {{Name}} (or any {{ColumnName}}) placeholders
PPTX_TEMPLATE_PATH=C:/path/to/certificate_template.pptx

# Email subject for attachment mode
ATTACHMENT_SUBJECT=Your Certificate of Participation — SIGGRAPH 2025

# -----------------------------------------------------------------------
# Optional settings
# -----------------------------------------------------------------------

# Delay between sends in seconds (default: 1.5)
SEND_DELAY_SECONDS=1.5

# Fallback subject if <title> tag is missing from HTML template
DEFAULT_SUBJECT=Your Certificate of Participation
