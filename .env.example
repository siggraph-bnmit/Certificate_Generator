# Gmail credentials
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Absolute path to your CSV file
CSV_FILE_PATH=C:/path/to/participants.csv

# -----------------------------------------------------------------------
# Mode — choose one per run:
#   html        → sends personalised HTML email (template/email_template.html)
#   attachment  → generates personalised PDF from PPTX and sends as attachment
#   qr          → generates QR codes and emails them to all participants
#   scan        → starts local scanner server at http://localhost:8080
# -----------------------------------------------------------------------
MODE=qr

# -----------------------------------------------------------------------
# Attachment mode settings (only used when MODE=attachment)
# -----------------------------------------------------------------------

# Absolute path to your PPTX template file
# Design the slide in PowerPoint with {{Name}} (or any {{ColumnName}}) placeholders
PPTX_TEMPLATE_PATH=C:/path/to/certificate_template.pptx

# Email subject for attachment mode
ATTACHMENT_SUBJECT=Your Certificate of Participation — SIGGRAPH 2025

# -----------------------------------------------------------------------
# QR code settings (used by MODE=qr and MODE=scan)
# -----------------------------------------------------------------------

# Secret key for HMAC token generation — change this, keep it secret
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET_KEY=change-this-to-a-long-random-secret

# -----------------------------------------------------------------------
# Supabase — required for cloud scanner CSV persistence (api.py only)
# Get these from: Supabase dashboard → Project Settings → API
# -----------------------------------------------------------------------

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_CSV_BUCKET=scanner-csv

# -----------------------------------------------------------------------
# Cloud deployment (api.py only)
# -----------------------------------------------------------------------

# Your Vercel frontend URL — enables CORS on the backend
FRONTEND_URL=https://your-frontend.vercel.app

# -----------------------------------------------------------------------
# Optional settings
# -----------------------------------------------------------------------

# Delay between sends in seconds (default: 0.6)
SEND_DELAY_SECONDS=0.6

# Fallback subject if <title> tag is missing from HTML template
DEFAULT_SUBJECT=Your Certificate of Participation
