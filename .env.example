# Gmail credentials
GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Absolute or relative path to your CSV file
CSV_FILE_PATH=C:/path/to/participants.csv

# Optional: override the delay between sends (default 1.5 seconds)
SEND_DELAY_SECONDS=1.5

# Optional: fallback subject if <title> tag is missing from HTML template
DEFAULT_SUBJECT=Your Certificate of Participation
